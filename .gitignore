# ═══════════════════════════════════════════════════════════════
# DjangoProject3 .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ──────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ── 虚拟环境 ───────────────────────────────────────────────────
venv/
.venv/
env/

# ── IDE ────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── 环境变量 ───────────────────────────────────────────────────
.env

# ── 模型权重 / 二进制 ──────────────────────────────────────────
*.pth
*.pt
*.ckpt
*.pkl
*.bin
*.h5
*.safetensors
*.onnx

# ── 数据集 / 数据文件 ─────────────────────────────────────────
*.dat
*.csv
*.jsonl
*.tsv

# ── 日志 / 备存 ───────────────────────────────────────────────
*.log
*.dump
*.sql
*.bak

# ── Office / 论文 ─────────────────────────────────────────────
*.xlsx
*.doc
*.docx
*.pdf

# ── 本地模型 / 索引 ───────────────────────────────────────────
local_models/
ml_artifacts/
faiss_movie_index/

# ── 海报（由脚本下载，不入版本控制）──────────────────────────
media/posters/

# ── 数据集目录 ────────────────────────────────────────────────
ml-1m/
myapp/management/commands/ml-1m/

# ── 根目录数据文件 ────────────────────────────────────────────
comments.jsonl
links.csv
tags.csv
ur.txt

# ── Django ─────────────────────────────────────────────────────
*.sqlite3
staticfiles/

# ── OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
