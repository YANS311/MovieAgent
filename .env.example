# ═══════════════════════════════════════════════════════════════
# DjangoProject3 环境变量配置
# 复制此文件为 .env 并填入真实值
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Django 核心配置 ────────────────────────────────────────────
# 必填：Django SECRET_KEY，用于加密会话等安全功能
# 生成命令：python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here-change-me

# 可选：调试模式（生产环境必须设为 False）
DJANGO_DEBUG=False

# 可选：允许访问的主机名，逗号分隔
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── MySQL 数据库 ───────────────────────────────────────────────
# 可选：数据库主机（Docker 内部使用 mysql）
DB_HOST=localhost

# 可选：数据库端口
DB_PORT=3306

# 可选：数据库名称
DB_NAME=django_movie

# 可选：数据库用户名
DB_USER=root

# 必填：数据库密码
DB_PASSWORD=your-mysql-password-here

# ── Neo4j 图数据库 ─────────────────────────────────────────────
# 可选：Neo4j 连接地址（Docker 内部使用 bolt://neo4j:7687）
NEO4J_URI=bolt://localhost:7687

# 可选：Neo4j 用户名
NEO4J_USER=neo4j

# 必填：Neo4j 密码
NEO4J_PASSWORD=your-neo4j-password-here

# ── Redis 缓存 ─────────────────────────────────────────────────
# 可选：Redis 连接地址
REDIS_URL=redis://127.0.0.1:6379/0

# ── Ollama LLM 服务 ────────────────────────────────────────────
# 可选：Ollama 服务地址
OLLAMA_BASE=http://localhost:11434

# 可选：使用的 LLM 模型名称
AGENT_LLM_MODEL=qwen3:4b-instruct

# ── TMDB API (可选，用于电影数据增强) ──────────────────────────
# 可选：TMDB API Key（用于 import_new_movies 和 enrich_tmdb_data 命令）
TMDB_API_KEY=your-tmdb-api-key-here

# ── 默认用户密码 (可选，用于批量导入用户) ──────────────────────
# 可选：import_movielens 命令创建用户的默认密码
DEFAULT_USER_PASSWORD=changeme

# ── 代理配置 (可选，用于访问 TMDB API) ─────────────────────────
# 可选：HTTP 代理地址
HTTP_PROXY=
HTTPS_PROXY=

# ── Docker Compose 专用 ────────────────────────────────────────
# 必填：MySQL root 密码（Docker Compose 使用）
MYSQL_ROOT_PASSWORD=your-mysql-root-password-here

# 必填：Neo4j 认证信息（格式：neo4j/your_password）
NEO4J_AUTH=neo4j/your-neo4j-password-here

# 可选：Uvicorn Worker 数量
UVICORN_WORKERS=8
